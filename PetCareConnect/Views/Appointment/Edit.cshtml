@model PetCareConnect.Models.ViewModels.AppointmentFormViewModel

@{
    ViewData["Title"] = "Edit Appointment";
}

<style>
  .appt-form-page {
    padding: 100px 60px 60px;
    max-width: 700px;
    margin: 0 auto;
  }

  .appt-form-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #6B7280;
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .appt-form-back:hover { color: #1A1A2E; }

  .appt-form-header { margin-bottom: 40px; }

  .appt-form-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4A7C59;
    margin-bottom: 8px;
  }

  .appt-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #1A1A2E;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .appt-form-card {
    background: white;
    border-radius: 24px;
    border: 1px solid #E5E0D8;
    padding: 40px;
    margin-bottom: 20px;
  }

  .appt-form-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1A1A2E;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #E5E0D8;
  }

  .pet-selector {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 12px;
  }

  .pet-option { display: none; }

  .pet-option-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 16px 12px;
    border-radius: 16px;
    border: 2px solid #E5E0D8;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }

  .pet-option-label:hover { border-color: #6BA07A; }
  .pet-option:checked + .pet-option-label { border-color: #4A7C59; background: rgba(74,124,89,0.06); }

  .pet-option-emoji {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: #FAF8F4;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    box-shadow: 0 2px 8px rgba(26,26,46,0.1);
  }

  .pet-option-avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 2px 8px rgba(26,26,46,0.1);
  }

  .pet-option-name { font-size: 0.85rem; font-weight: 600; color: #1A1A2E; }
  .pet-option-breed { font-size: 0.72rem; color: #6B7280; }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .service-option { display: none; }

  .service-option-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 10px;
    border-radius: 14px;
    border: 2px solid #E5E0D8;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }

  .service-option-label:hover { border-color: #6BA07A; }
  .service-option:checked + .service-option-label { border-color: #4A7C59; background: rgba(74,124,89,0.06); }

  .service-icon { font-size: 1.4rem; }
  .service-name { font-size: 0.8rem; font-weight: 600; color: #1A1A2E; }

  .datetime-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #1A1A2E;
    margin-bottom: 8px;
  }

  .form-input {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid #E5E0D8;
    border-radius: 12px;
    font-size: 0.9rem;
    font-family: 'DM Sans', sans-serif;
    color: #1A1A2E;
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .form-input:focus {
    outline: none;
    border-color: #4A7C59;
    box-shadow: 0 0 0 3px rgba(74,124,89,0.1);
  }

  .form-error { font-size: 0.75rem; color: #EF4444; margin-top: 6px; display: block; }

  .form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  .btn-cancel {
    background: white;
    border: 1.5px solid #E5E0D8;
    padding: 13px 28px;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6B7280;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-cancel:hover { border-color: #1A1A2E; color: #1A1A2E; }

  .btn-save {
    background: #1A1A2E;
    border: none;
    padding: 13px 32px;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
  }

  .btn-save:hover { background: #4A7C59; transform: translateY(-1px); }

  @@media (max-width: 600px) {
    .appt-form-page { padding: 90px 20px 40px; }
    .appt-form-card { padding: 24px; }
    .service-grid { grid-template-columns: repeat(2, 1fr); }
    .datetime-row { grid-template-columns: 1fr; }
  }
</style>

<div class="appt-form-page">

  <a asp-controller="Appointment" asp-action="Details" asp-route-id="@Model.AppointmentID" class="appt-form-back">← Back to Appointment</a>

  <div class="appt-form-header">
    <div class="appt-form-label">Edit Appointment</div>
    <h1 class="appt-form-title">Update Appointment 📅</h1>
  </div>

  <form asp-controller="Appointment" asp-action="Edit" asp-route-id="@Model.AppointmentID" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="AppointmentID" value="@Model.AppointmentID" />

    <!-- PET -->
    <div class="appt-form-card">
      <div class="appt-form-card-title">Which pet is this for?</div>
      <div class="pet-selector">
        @foreach (var pet in Model.Pets)
        {
          <div>
            <input type="radio" name="PetID" id="pet_@pet.PetID" value="@pet.PetID" class="pet-option"
                   @(pet.PetID == Model.PetID ? "checked" : "") />
            <label for="pet_@pet.PetID" class="pet-option-label">
              @if (!string.IsNullOrEmpty(pet.PhotoUrl))
              {
                <img src="@pet.PhotoUrl" alt="@pet.Name" class="pet-option-avatar" />
              }
              else
              {
                <div class="pet-option-emoji">@PetCareConnect.Helpers.PetHelper.GetAvatarEmoji(pet.Breed)</div>
              }
              <div>
                <div class="pet-option-name">@pet.Name</div>
                <div class="pet-option-breed">@pet.Breed</div>
              </div>
            </label>
          </div>
        }
      </div>
    </div>

    <!-- SERVICE TYPE -->
    <div class="appt-form-card">
      <div class="appt-form-card-title">What type of appointment?</div>
      <div class="service-grid">
        @{
          var serviceIcons = new Dictionary<string, string>
          {
            { "Checkup", "🩺" }, { "Vaccination", "💉" }, { "Grooming", "✂️" },
            { "Dental", "🦷" }, { "Emergency", "🚨" }, { "Other", "📋" }
          };
        }
        @foreach (var service in PetCareConnect.Models.ViewModels.AppointmentFormViewModel.ServiceTypes)
        {
          <div>
            <input type="radio" name="ServiceType" id="service_@service" value="@service" class="service-option"
                   @(service == Model.ServiceType ? "checked" : "") />
            <label for="service_@service" class="service-option-label">
              <span class="service-icon">@serviceIcons[service]</span>
              <span class="service-name">@service</span>
            </label>
          </div>
        }
      </div>
    </div>

    <!-- DATE & TIME -->
    <div class="appt-form-card">
      <div class="appt-form-card-title">When?</div>
      <div class="datetime-row">
        <div>
          <label class="form-label">Date</label>
          <input type="date" name="AppointmentDateTime" id="apptDate" class="form-input"
                 value="@Model.AppointmentDateTime.ToLocalTime().ToString("yyyy-MM-dd")"
                 min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" required />
        </div>
        <div>
          <label class="form-label">Time</label>
          <input type="time" name="AppointmentTime" id="apptTime" class="form-input"
                 value="@Model.AppointmentDateTime.ToLocalTime().ToString("HH:mm")" required />
        </div>
      </div>
    </div>

    <div class="form-actions">
      <a asp-controller="Appointment" asp-action="Details" asp-route-id="@Model.AppointmentID" class="btn-cancel">Cancel</a>
      <button type="submit" class="btn-save">Save Changes</button>
    </div>

  </form>
</div>

<script>
  document.querySelector('form').addEventListener('submit', function(e) {
    const date = document.getElementById('apptDate').value;
    const time = document.getElementById('apptTime').value;
    if (date && time) {
      const combined = document.createElement('input');
      combined.type = 'hidden';
      combined.name = 'AppointmentDateTime';
      combined.value = date + 'T' + time;
      document.getElementById('apptDate').removeAttribute('name');
      this.appendChild(combined);
    }
  });
</script>
