        </div>
        <div class="feature-card reveal">
            <div class="feature-icon">📍</div>
            <div class="feature-title">Local Network</div>
            <p class="feature-desc">Discover top-rated pet care professionals near you with transparent reviews and fair pricing.</p>
        </div>
    </div>
    </div>
</section>

