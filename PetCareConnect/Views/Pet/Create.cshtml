@model PetCareConnect.Models.ViewModels.PetFormViewModel

@{
    ViewData["Title"] = "Add a Pet";
}

<style>
  .pet-form-page {
    padding: 100px 60px 60px;
    max-width: 800px;
    margin: 0 auto;
  }

  .pet-form-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #6B7280;
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .pet-form-back:hover { color: #1A1A2E; }

  .pet-form-header { margin-bottom: 40px; }

  .pet-form-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4A7C59;
    margin-bottom: 8px;
  }

  .pet-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #1A1A2E;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .pet-form-card {
    background: white;
    border-radius: 24px;
    border: 1px solid #E5E0D8;
    padding: 40px;
    margin-bottom: 20px;
  }

  .pet-form-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1A1A2E;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #E5E0D8;
  }

  /* ─── PHOTO UPLOAD ─── */
  .photo-upload-area {
    border: 2px dashed #E5E0D8;
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .photo-upload-area:hover { border-color: #4A7C59; background: rgba(74,124,89,0.02); }
  .photo-upload-area.has-photo { border-style: solid; border-color: #4A7C59; padding: 0; }

  .photo-upload-icon { font-size: 2.5rem; margin-bottom: 12px; }

  .photo-upload-text {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1A1A2E;
    margin-bottom: 4px;
  }

  .photo-upload-hint { font-size: 0.78rem; color: #6B7280; }

  .photo-preview-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 14px;
    display: none;
  }

  /* ─── FORM ─── */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group { margin-bottom: 20px; }
  .form-group:last-child { margin-bottom: 0; }

  .form-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #1A1A2E;
    margin-bottom: 8px;
  }

  .form-label span { color: #6B7280; font-weight: 400; }

  .form-input {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid #E5E0D8;
    border-radius: 12px;
    font-size: 0.9rem;
    font-family: 'DM Sans', sans-serif;
    color: #1A1A2E;
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .form-input:focus {
    outline: none;
    border-color: #4A7C59;
    box-shadow: 0 0 0 3px rgba(74,124,89,0.1);
  }

  textarea.form-input {
    resize: vertical;
    min-height: 120px;
  }

  .form-error {
    font-size: 0.75rem;
    color: #EF4444;
    margin-top: 4px;
  }

  /* ─── ACTIONS ─── */
  .form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  .btn-cancel {
    background: white;
    border: 1.5px solid #E5E0D8;
    padding: 13px 28px;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6B7280;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-cancel:hover { border-color: #1A1A2E; color: #1A1A2E; }

  .btn-save {
    background: #1A1A2E;
    border: none;
    padding: 13px 32px;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
  }

  .btn-save:hover { background: #4A7C59; transform: translateY(-1px); }

  @@media (max-width: 600px) {
    .pet-form-page { padding: 90px 20px 40px; }
    .form-row { grid-template-columns: 1fr; }
    .pet-form-card { padding: 24px; }
  }
</style>

<div class="pet-form-page">

  <a asp-controller="Dashboard" asp-action="Index" class="pet-form-back">← Back to Dashboard</a>

  <div class="pet-form-header">
    <div class="pet-form-label">Your Pets</div>
    <h1 class="pet-form-title">Add a New Pet 🐾</h1>
  </div>

  <form asp-controller="Pet" asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- PHOTO -->
    <div class="pet-form-card">
      <div class="pet-form-card-title">Pet Photo <span style="font-weight:400;color:#6B7280;font-size:0.9rem;">— optional</span></div>
      <div class="photo-upload-area" id="uploadArea" onclick="document.getElementById('photoInput').click()">
        <img id="photoPreview" class="photo-preview-img" alt="Preview" />
        <div id="uploadPlaceholder">
          <div class="photo-upload-icon">📷</div>
          <div class="photo-upload-text">Click to upload a photo</div>
          <div class="photo-upload-hint">JPG, PNG or GIF · Max 5MB</div>
        </div>
      </div>
      <input type="file" id="photoInput" name="Photo" accept="image/*" style="display:none" onchange="previewPhoto(this)" />
    </div>

    <!-- BASIC INFO -->
    <div class="pet-form-card">
      <div class="pet-form-card-title">Basic Information</div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Pet Name *</label>
          <input asp-for="Name" class="form-input" placeholder="e.g. Biscuit" />
          <span asp-validation-for="Name" class="form-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label">Breed *</label>
          <input asp-for="Breed" class="form-input" placeholder="e.g. Golden Retriever" />
          <span asp-validation-for="Breed" class="form-error"></span>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Age *  <span>(in years)</span></label>
          <input asp-for="Age" type="number" class="form-input" placeholder="e.g. 3" min="0" max="50" />
          <span asp-validation-for="Age" class="form-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label">Color <span>— optional</span></label>
          <input asp-for="Color" class="form-input" placeholder="e.g. Golden, Black & White" />
        </div>
      </div>
    </div>

    <!-- MEDICAL NOTES -->
    <div class="pet-form-card">
      <div class="pet-form-card-title">Medical Notes <span style="font-weight:400;color:#6B7280;font-size:0.9rem;">— optional</span></div>
      <div class="form-group">
        <textarea asp-for="MedicalNotes" class="form-input" placeholder="Any allergies, dietary needs, ongoing conditions, food brand, vet notes..."></textarea>
      </div>
    </div>

    <div class="form-actions">
      <a asp-controller="Dashboard" asp-action="Index" class="btn-cancel">Cancel</a>
      <button type="submit" class="btn-save">Add Pet 🐾</button>
    </div>

  </form>
</div>

<script>
  function previewPhoto(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        const preview = document.getElementById('photoPreview');
        const placeholder = document.getElementById('uploadPlaceholder');
        const area = document.getElementById('uploadArea');
        preview.src = e.target.result;
        preview.style.display = 'block';
        placeholder.style.display = 'none';
        area.classList.add('has-photo');
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>
