@model List<PetCareConnect.Models.Prescription>

@functions {
  string GetBadgeClass(PetCareConnect.Models.Prescription rx) {
    if (rx.ExpirationDate < DateTime.UtcNow) return "rx-expired";
    return rx.RefillStatus switch {
      "Refills Available" => "rx-available",
      "Refill Requested"  => "rx-requested",
      _                   => "rx-none"
    };
  }
  string GetBadgeText(PetCareConnect.Models.Prescription rx) {
    if (rx.ExpirationDate < DateTime.UtcNow) return "Expired";
    return rx.RefillStatus;
  }
}

@{
    ViewData["Title"] = "Prescriptions";
}

<style>
  .rx-page {
    padding: 100px 60px 60px;
    max-width: 900px;
    margin: 0 auto;
  }

  .rx-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #6B7280;
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .rx-back:hover { color: #1A1A2E; }

  .rx-header { margin-bottom: 40px; }

  .rx-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4A7C59;
    margin-bottom: 8px;
  }

  .rx-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #1A1A2E;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .rx-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .rx-item {
    background: white;
    border-radius: 18px;
    border: 1px solid #E5E0D8;
    padding: 22px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .rx-item:hover {
    border-color: #4A7C59;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(74,124,89,0.1);
  }

  .rx-pet-avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #E5E0D8;
    flex-shrink: 0;
  }

  .rx-pet-emoji {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: #FAF8F4;
    border: 2px solid #E5E0D8;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .rx-info { flex: 1; min-width: 0; }

  .rx-med-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1A1A2E;
    margin-bottom: 3px;
  }

  .rx-meta {
    font-size: 0.8rem;
    color: #6B7280;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .rx-meta span { display: flex; align-items: center; gap: 4px; }

  .rx-badge {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .rx-available { background: rgba(74,124,89,0.1); color: #4A7C59; }
  .rx-requested { background: rgba(245,158,11,0.1); color: #D97706; }
  .rx-none      { background: rgba(107,114,128,0.1); color: #6B7280; }
  .rx-expired   { background: rgba(239,68,68,0.1); color: #EF4444; }

  .rx-chevron {
    color: #E5E0D8;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .rx-empty {
    text-align: center;
    padding: 60px 20px;
    background: white;
    border-radius: 20px;
    border: 1px solid #E5E0D8;
  }

  .rx-empty-icon { font-size: 3rem; margin-bottom: 16px; }

  .rx-empty-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #1A1A2E;
    margin-bottom: 8px;
  }

  .rx-empty-sub { font-size: 0.88rem; color: #6B7280; }

  .rx-group-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6B7280;
    margin: 28px 0 10px;
  }

  @@media (max-width: 600px) {
    .rx-page { padding: 90px 20px 40px; }
    .rx-meta { gap: 8px; }
  }
</style>

<div class="rx-page">

  <a asp-controller="Dashboard" asp-action="Index" class="rx-back">← Back to Dashboard</a>

  <div class="rx-header">
    <div class="rx-label">Medications</div>
    <h1 class="rx-title">Prescriptions 💊</h1>
  </div>

  @if (!Model.Any())
  {
    <div class="rx-empty">
      <div class="rx-empty-icon">💊</div>
      <div class="rx-empty-title">No prescriptions on file</div>
      <div class="rx-empty-sub">Prescriptions added by your vet will appear here.</div>
    </div>
  }
  else
  {
    var grouped = Model.GroupBy(p => p.Pet.Name);
    @foreach (var group in grouped)
    {
      <div class="rx-group-label">@group.Key</div>
      <div class="rx-list">
        @foreach (var rx in group)
        {
          <a asp-controller="Prescription" asp-action="Details" asp-route-id="@rx.PrescriptionID" class="rx-item">
            @if (!string.IsNullOrEmpty(rx.Pet.PhotoUrl))
            {
              <img src="@rx.Pet.PhotoUrl" alt="@rx.Pet.Name" class="rx-pet-avatar" />
            }
            else
            {
              <div class="rx-pet-emoji">@PetCareConnect.Helpers.PetHelper.GetAvatarEmoji(rx.Pet.Breed)</div>
            }
            <div class="rx-info">
              <div class="rx-med-name">@rx.MedicationName</div>
              <div class="rx-meta">
                <span>💉 @rx.Dosage</span>
                <span>📅 Expires @rx.ExpirationDate.ToString("MMM d, yyyy")</span>
              </div>
            </div>
            <div class="rx-badge @GetBadgeClass(rx)">@GetBadgeText(rx)</div>
            <div class="rx-chevron">›</div>
          </a>
        }
      </div>
    }
  }

</div>
