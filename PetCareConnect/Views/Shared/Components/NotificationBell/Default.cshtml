@model List<PetCareConnect.Models.Notification>

@{
    var unreadCount = Model.Count(n => n.Status == "Unread");
}

<div class="notif-bell-wrap">
  <button class="notif-bell-btn" onclick="toggleNotifDropdown()" id="notifBellBtn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    @if (unreadCount > 0)
    {
      <span class="notif-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
    }
  </button>

  <div class="notif-dropdown" id="notifDropdown">
    <div class="notif-dropdown-header">
      <span class="notif-dropdown-title">Notifications</span>
      @if (unreadCount > 0)
      {
        <form asp-controller="Notification" asp-action="MarkAllRead" method="post" style="display:inline;">
          @Html.AntiForgeryToken()
          <button type="submit" class="notif-mark-all">Mark all read</button>
        </form>
      }
    </div>

    <div class="notif-list">
      @if (!Model.Any())
      {
        <div class="notif-empty">
          <span>🔔</span>
          <p>You're all caught up!</p>
        </div>
      }
      else
      {
        @foreach (var notif in Model)
        {
          <form asp-controller="Notification" asp-action="MarkRead" method="post"
                class="notif-item @(notif.Status == "Unread" ? "notif-unread" : "")">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@notif.NotificationID" />
            <button type="submit" class="notif-item-inner">
              <div class="notif-dot @(notif.Status == "Unread" ? "notif-dot-active" : "")"></div>
              <div class="notif-content">
                <p class="notif-msg">@notif.Message</p>
                <span class="notif-time">@GetTimeAgo(notif.DateCreated)</span>
              </div>
            </button>
          </form>
        }
      }
    </div>
  </div>
</div>

@functions {
  string GetTimeAgo(DateTime dt)
  {
    var diff = DateTime.UtcNow - dt;
    if (diff.TotalMinutes < 1) return "just now";
    if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
    if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
    if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
    return dt.ToLocalTime().ToString("MMM d");
  }
}
